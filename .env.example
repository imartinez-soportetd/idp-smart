# ============================================
# IDP-SMART Configuration (LocalAI Migrated)
# ============================================
# Copiar a .env y configurar según tu entorno

# === Database ===
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=admin_user
DB_PASSWORD=your-secure-password-change-this
DB_NAME=rpp_qa

# === Redis/Valkey ===
VALKEY_URL=redis://valkey:6379/0

# === MinIO (Object Storage) ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=minio_password123
MINIO_BUCKET=idp-documents
MINIO_SECURE=false

# ============================================
# === LLM CONFIGURATION (LocalAI - PRIMARY) ===
# ============================================
# Cambiar LLM_PROVIDER a:
# - "localai"  (Recomendado - LocalAI)
# - "ollama"   (Legacy - Ollama)
# - "google"   (Gemini API)

LLM_PROVIDER=localai

# === LocalAI / OpenAI Compatible API ===
# Nota: LocalAI expone una API 100% compatible con OpenAI
LOCALAI_BASE_URL=http://localai:8080/v1
LOCALAI_MODEL=granite-vision
LOCALAI_TEMPERATURE=0.1
LOCALAI_CONTEXT_SIZE=8192
LOCALAI_MAX_TOKENS=2048
LOCALAI_TIMEOUT=300

# === Ollama (Legacy - Para fallback) ===
# Solo necesario si mantienes Ollama como alternativa
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# === Google Gemini (Fallback/Alternativa) ===
# Obtener en: https://ai.google.dev/
GOOGLE_API_KEY=

# ============================================
# === HARDWARE OPTIMIZATION ===
# ============================================

# CPU Configuration
THREADS=4  # Ajustar a número de cores disponibles (8, 16, etc.)

# GPU Configuration (Descomenta si tienes NVIDIA GPU)
# CUDA_VISIBLE_DEVICES=0  # ID de GPU (0, 1, 2, etc.)
# GPU_LAYERS=50           # Layers en GPU (mayor = más VRAM usado)

# OpenVINO (Intel CPU Optimization)
# INTEL_OPENVINO_ENABLED=1
# OPENVINO_DEVICE=CPU
# OPENVINO_NUM_INFER_REQUESTS=4

# Memory Management
# CONTEXT_SIZE=8192  # Definifo en Docker compose
# BATCH_SIZE=512     # Batch inference size

# ============================================
# === LOGGING & DEBUG ===
# ============================================
DEBUG=0
LOG_LEVEL=INFO

